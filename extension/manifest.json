{
  "manifest_version": 3,
  "name": "BetGol Capturador",
  "version": "1.3",
  "description": "Captura dados do futebol virtual da Bet365 para o BetGol",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://*.bet365.bet.br/*",
    "https://*.bet365.com/*",
    "https://betgol-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
