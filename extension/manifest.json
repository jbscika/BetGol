{
  "manifest_version": 3,
  "name": "BetGol Capturador",
  "version": "1.0",
  "description": "Captura dados do futebol virtual da Bet365 para o BetGol",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://www.bet365.bet.br/*",
    "https://betgol-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bet365.bet.br/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
